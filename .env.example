# Segurança do Banco de Dados
# Obrigatório: Altere estas senhas para algo forte em produção!
DB_NAME=greviadb
DB_USER=grevia_user
DB_PASSWORD=coloque_uma_senha_forte_aqui
DB_ROOT_PASSWORD=coloque_outra_senha_forte_aqui

# Serviço de E-mail (Obrigatório para recuperação de senha funcionar no OCI)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu_email@gmail.com
SPRING_MAIL_PASSWORD=sua_senha_de_app_ou_credencial
