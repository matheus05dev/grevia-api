# Banco de Dados
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=greviadb
MYSQLUSER=user
MYSQLPASSWORD=admin

# JWT
# Gere uma chave forte com: openssl rand -base64 64
JWT_SECRET=substitua_por_uma_chave_secreta_longa_e_segura_aqui
JWT_EXPIRATION_MS=86400000

# E-mail (Opcional para desenvolvimento local)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=sua-senha-de-app
